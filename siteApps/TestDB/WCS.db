# ============================================================
# 3. Control Logic (Scenario A & C)
# ============================================================

# [Logic] Main Control Loop (Fanout to sub-logics)
# Scans every 1 second to keep checking conditions
record(fanout, "WTS:CTRL:LOOP") {
    field(SCAN, "1 second")
    field(LNK1, "WTS:CTRL:INTERLOCK")
    field(LNK2, "WTS:CTRL:P1_SPEED")
    field(LNK3, "WTS:CTRL:CHEM_DOSE")
    field(LNK4, "WTS:CTRL:BACKWASH_CHECK")
}

# [Interlock] Emergency Stop Logic (Scenario C)
# Stops system if Faults exist or Levels are critical
record(calcout, "WTS:CTRL:INTERLOCK") {
    field(INPA, "WTS:P1:FAULT")
    field(INPB, "WTS:P2:FAULT")
    field(INPC, "WTS:CLEAN_TANK:LVL")
    field(INPD, "WTS:RAW_TANK:LVL")
    field(INPE, "WTS:SYS:STATUS")
    
    # Logic: If (Fault=1 OR CleanLvl>95 OR RawLvl<10) AND System is ON
    # CALC: (A || B || C>95 || D<10) && E
    field(CALC, "(A || B || C>95 || D<10) && E")
    
    # If Result is 1 (Emergency condition met), Write 0 to System Status
    field(OOPT, "When Non-zero")
    field(OUT,  "WTS:SYS:STATUS PP") 
    field(VAL,  "0") # Write 0 (Stop)
}

# [Logic] Pump 1 Speed Control (Scenario A)
# Python: if LVL < 30: 100 ... else 20
record(calcout, "WTS:CTRL:P1_SPEED") {
    field(INPA, "WTS:CLEAN_TANK:LVL")
    field(INPB, "WTS:SYS:STATUS")
    
    # Only calculate if System is Running (B=1)
    # A<30?100 : (A<50?80 : (A<70?60 : (A<85?40 : 20)))
    field(CALC, "B?(A<30?100:(A<50?80:(A<70?60:(A<85?40:20)))):0")
    
    field(OUT,  "WTS:P1:SPEED_SP PP")
    field(OOPT, "Every Time")
}

# [Logic] Chemical Dosing Control (Scenario A)
# Python: Base(20) + (7-pH)*10 + (Turb>200 ? (Turb-200)*0.1 : 0)
record(calcout, "WTS:CTRL:CHEM_DOSE") {
    field(INPA, "WTS:RAW_TANK:PH")
    field(INPB, "WTS:RAW_TANK:TURB")
    field(INPC, "WTS:SYS:STATUS")
    
    # Logic: Base(20) + pH_Correction + Turb_Correction
    # MAX(0, MIN(100, Result)) for safety limits
    field(CALC, "C?MAX(0,MIN(100, 20 + (7-A)*10 + (B>200?(B-200)*0.1:0))):0")
    
    field(OUT,  "WTS:CHEM:DOSE_SP PP")
    field(OOPT, "Every Time")
}

# ============================================================
# 4. Backwash Sequence (Scenario B)
# ============================================================

# [Logic] Backwash Trigger Check
# Checks if DP > 40kPa while System is Running
record(calcout, "WTS:CTRL:BACKWASH_CHECK") {
    field(INPA, "WTS:FILTER:DP")
    field(INPB, "WTS:SYS:STATUS")
    field(INPC, "WTS:SEQ:BACKWASH.PACT") # Check if sequence is already active
    
    # If DP>40 AND System ON AND Sequence Not Active
    field(CALC, "(A>40) && B && !C")
    
    field(OOPT, "When Non-zero")
    field(OUT,  "WTS:SEQ:BACKWASH.PROC") # Trigger the sequence
}

# [Sequence] The Actual Backwash State Machine
# Delays are set in the DLYx fields (Seconds)
record(seq, "WTS:SEQ:BACKWASH") {
    # Step 1: Stop Pump 1
    field(DLY1, "0")
    field(DOL1, "0")
    field(LNK1, "WTS:P1:CMD PP")
    
    # Step 2: Wait 5s (Residual Drain) then Open Backwash Valve
    field(DLY2, "5.0")
    field(DOL2, "1")
    field(LNK2, "WTS:FILTER:BACKWASH PP")
    
    # Step 3: Maintain for 5 mins (300s) then Close Valve
    # Note: Using 10s for demo/testing convenience (Change to 300 for real)
    field(DLY3, "10.0") 
    field(DOL3, "0")
    field(LNK3, "WTS:FILTER:BACKWASH PP")
    
    # Step 4: Reset Differential Pressure (Simulated Logic)
    field(DLY4, "1.0")
    field(DOL4, "5.0")
    field(LNK4, "WTS:FILTER:DP PP") # Reset DP to 5 kPa
    
    # Step 5: Wait 10s (Stabilize) then Restart Pump 1
    field(DLY5, "10.0")
    field(DOL5, "1")
    field(LNK5, "WTS:P1:CMD PP")
}

# ============================================================
# 5. System Simulation (Physics Model)
# ============================================================

# [Sim] Simulation Heartbeat
record(fanout, "WTS:SIM:LOOP") {
    field(SCAN, "1 second")
    field(LNK1, "WTS:SIM:RAW_LVL")
    field(LNK2, "WTS:SIM:CLEAN_LVL")
    field(LNK3, "WTS:SIM:DP")
    field(LNK4, "WTS:SIM:TEMP")
}

# [Sim] Raw Tank Level Simulation
# LVL += (Inflow - Outflow) * dt
# Inflow = V1_CMD * 10
# Outflow = P1_SPEED * 0.1
record(calcout, "WTS:SIM:RAW_LVL") {
    field(INPA, "WTS:RAW_TANK:LVL") # Current Level
    field(INPB, "WTS:V1:CMD")       # Valve Status
    field(INPC, "WTS:P1:SPEED_SP")  # Pump Speed
    
    # A + (Inflow - Outflow) * Scaling
    field(CALC, "MAX(0, MIN(100, A + (B*10 - C*0.1)*0.05))")
    
    field(OUT,  "WTS:RAW_TANK:LVL PP") # Write back to sensor
    field(OOPT, "Every Time")
}

# [Sim] Clean Tank Level Simulation
record(calcout, "WTS:SIM:CLEAN_LVL") {
    field(INPA, "WTS:CLEAN_TANK:LVL")
    field(INPB, "WTS:P1:SPEED_SP")    # Filter Flow (Simulated from P1)
    field(INPC, "WTS:P2:SPEED_SP")    # Outflow Pump
    
    # A + (Inflow - Outflow)
    field(CALC, "MAX(0, MIN(100, A + (B*0.1 - C*0.15)*0.05))")
    
    field(OUT,  "WTS:CLEAN_TANK:LVL PP")
    field(OOPT, "Every Time")
}

# [Sim] Filter DP Simulation
# Increases over time if Pump1 is running, Resets via Sequence
record(calcout, "WTS:SIM:DP") {
    field(INPA, "WTS:FILTER:DP")
    field(INPB, "WTS:P1:CMD")
    field(INPC, "WTS:P1:SPEED_SP")
    
    # DP increases proportional to Flow
    field(CALC, "B ? MIN(50, A + (C * 0.005)) : A")
    
    field(OUT,  "WTS:FILTER:DP PP")
    field(OOPT, "Every Time")
}

# [Sim] Temperature Simulation (Sine wave)
# 15 + 5 * sin(t)
record(calcout, "WTS:SIM:TEMP") {
    field(INPA, "WTS:SIM:TEMP.VAL") # Self for counter or use system time
    
    # Simple oscillator for demo: 15 + 5*SIN(VAL)
    # Note: In real sim, use time variable. Here strictly using calc.
    # Let's just create a noisy value around 15C
    field(CALC, "15 + 5*RNDM") 
    
    field(OUT,  "WTS:RAW_TANK:TEMP PP")
    field(OOPT, "Every Time")
}

# [Sim] Pump Feedback Simulation
# Simple Logic: FB follows CMD immediately (for this demo)
record(calcout, "WTS:SIM:P1_FB") {
    field(INPA, "WTS:P1:CMD")
    field(CALC, "A")
    field(OUT,  "WTS:P1:RUN_FB PP")
    field(SCAN, "1 second")
}
