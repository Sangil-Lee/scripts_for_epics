# ------------------------------------------------------------------
# EPICS RTP (Rapid Thermal Processing) Control System
# Logic: Split-Range Control (Heating & Active Cooling)
# Macro: $(P) = Prefix, $(R) = Device Name
# ------------------------------------------------------------------

# ==================================================================
# 1. 사용자 설정 (Process Recipe)
# ==================================================================

# 1-1. 목표 온도
record(ao, "$(P)$(R)Target") {
    field(DESC, "Target Temp")
    field(EGU,  "degC")
    field(VAL,  "25.0")
    field(PINI, "YES")
}

# 1-2. 공정 시작 (Run)
record(bo, "$(P)$(R)Run") {
    field(DESC, "Process Start")
    field(ZNAM, "Idle")
    field(ONAM, "Run")
    field(VAL,  "0")
}

# ==================================================================
# 2. 통합 제어기 (Split-Range Controller)
# ==================================================================

# 2-1. 온도 에러 및 제어 출력 계산
# 출력 범위: -100 (최대냉각) ~ +100 (최대가열)
record(calc, "$(P)$(R)Ctrl:Out") {
    field(DESC, "Main Control Output")
    field(SCAN, ".1 second") # RTP는 매우 빠르므로 빠른 스캔 필수
    
    # 입력
    field(INPA, "$(P)$(R)Target NPP")  # 목표
    field(INPB, "$(P)$(R)Temp NPP")    # 현재온도
    field(INPC, "$(P)$(R)Run NPP")     # Run 상태
    
    # 로직 (P제어):
    # Error = A - B
    # Gain = 5.0 (매우 공격적인 제어)
    # Run(C)이 0이면 출력 0 (Off)
    # Run(C)이 1이면 (Error * Gain) 계산
    # 결과가 -100~100 사이가 되도록 제한 (Clamping)
    field(CALC, "C ? MAX(-100, MIN(100, (A-B)*5.0)) : 0")
    
    field(PREC, "1")
    # 계산 후 히터 분배 로직으로 이동
    field(FLNK, "$(P)$(R)Split:Heat")
}

# 2-2. 히터 출력 분배 (Heating Split)
# Ctrl:Out이 0보다 클 때만 동작 (0~100)
record(calc, "$(P)$(R)Split:Heat") {
    field(DESC, "Heater Output (0~100)")
    field(INPA, "$(P)$(R)Ctrl:Out NPP")
    
    # A가 양수면 A 그대로, 음수면 0
    field(CALC, "MAX(0, A)")
    field(EGU,  "%")
    # 계산 후 쿨러 분배 로직으로 이동
    field(FLNK, "$(P)$(R)Split:Cool")
}

# 2-3. 쿨러 출력 분배 (Cooling Split)
# Ctrl:Out이 0보다 작을 때만 동작 (0~100)
record(calc, "$(P)$(R)Split:Cool") {
    field(DESC, "Cooling Valve (0~100)")
    field(INPA, "$(P)$(R)Ctrl:Out NPP")
    
    # A가 음수면 절대값 취함, 양수면 0
    # 예: A가 -50이면 쿨러는 50% 개방
    field(CALC, "MAX(0, -A)")
    field(EGU,  "%")
    
    # [수정됨] FLNK 대상을 실제 존재하는 Temp 레코드로 연결
    field(FLNK, "$(P)$(R)Temp")
}

# ==================================================================
# 3. RTP 물리 모델 (Physics Simulation)
# ==================================================================

# 3-1. 챔버 온도 시뮬레이션
# RTP는 열용량이 작아 온도가 순식간에 오르고 내립니다.
record(calc, "$(P)$(R)Temp") {
    field(DESC, "Wafer Temperature")
    # SCAN은 Passive (Split:Cool에서 FLNK로 호출됨)
    
    # 입력
    field(INPA, "$(P)$(R)Temp NPP")        # 현재온도 (Self)
    field(INPB, "$(P)$(R)Split:Heat NPP")  # 히터 파워
    field(INPC, "$(P)$(R)Split:Cool NPP")  # 쿨링 파워
    
    # 물리 상수
    # Ambient: 25도
    # Heat Gain: B * 2.0 (파워 1%당 2도 상승 - 매우 빠름)
    # Active Cool: C * 3.0 (쿨러 1%당 3도 하강 - 강력한 냉각)
    # Natural Loss: (A-25)*0.01 (자연 냉각)
    
    # 공식: Temp = Temp + Heat - ActiveCool - NaturalCool
    field(CALC, "MAX(25, A + (B*2.0) - (C*3.0) - ((A-25.0)*0.01))")
    
    field(EGU,  "degC")
    field(PREC, "1")
}
