# ------------------------------------------------------------------
# EPICS PWM (Pulse Width Modulation) Generator
# Macro: $(P) = Prefix, $(R) = Device Name
# ------------------------------------------------------------------

# 1. 제어 파라미터 (Controls)

# 파형의 상한값 (High Level)
record(ao, "$(P)$(R)HighVal") {
    field(DESC, "High Level Value")
    field(VAL,  "5")
    field(PINI, "YES")
}

# 파형의 하한값 (Low Level)
record(ao, "$(P)$(R)LowVal") {
    field(DESC, "Low Level Value")
    field(VAL,  "0")
    field(PINI, "YES")
}

# 전체 주기 (Period in Ticks)
# 예: Scan rate 0.1초일 때, Period가 100이면 전체 주기는 10초
record(ao, "$(P)$(R)Period") {
    field(DESC, "Total Cycle Length (Ticks)")
    field(VAL,  "100")
    field(PINI, "YES")
}

# 펄스 폭 (Pulse Width in Ticks)
# 이 값만큼 High 상태가 유지됩니다. (Duty Cycle 제어)
record(ao, "$(P)$(R)Width") {
    field(DESC, "High Duration (Ticks)")
    field(VAL,  "30")  # 초기값: 30% Duty Cycle
    field(PINI, "YES")
}

# 실행 제어 (Run/Stop)
record(bo, "$(P)$(R)Run") {
    field(DESC, "PWM Run Control")
    field(ZNAM, "Stop")
    field(ONAM, "Run")
    field(VAL,  "0")
}

# ------------------------------------------------------------------
# 핵심 로직 (Core Logic)
# ------------------------------------------------------------------

# 2. 카운터 레코드 (Time Counter)
# 주기적으로 실행되며 0부터 (Period-1)까지 숫자를 셉니다.
# A: 현재 카운트 값 (Self)
# B: 전체 주기 (Period)
# C: 실행 여부 (Run)
record(calc, "$(P)$(R)Counter") {
    field(DESC, "Internal Counter")
    field(SCAN, "1 second")       # 시간 해상도 (조절 가능)
    field(INPA, "$(P)$(R)Counter NPP")
    field(INPB, "$(P)$(R)Period NPP")
    field(INPC, "$(P)$(R)Run NPP")
    
    # 로직: 
    # Run(C)이 1이면, (현재값 A + 1)을 주기 B로 나눈 나머지값 저장.
    # Run이 0이면 카운터를 0으로 리셋.
    field(CALC, "C ? (A+1)%B : 0")
    
    # 카운트가 변경되면 출력 계산 레코드를 트리거
    field(FLNK, "$(P)$(R)Output")
}

# 3. 출력 결정 레코드 (Output Comparator)
# 카운터 값과 펄스 폭을 비교하여 출력을 결정합니다.
# A: 현재 카운터 값 (from Counter Record)
# B: 설정된 펄스 폭 (Width)
# C: High 값
# D: Low 값
record(calc, "$(P)$(R)Output") {
    field(DESC, "PWM Square Output")
    field(INPA, "$(P)$(R)Counter NPP")
    field(INPB, "$(P)$(R)Width NPP")
    field(INPC, "$(P)$(R)HighVal NPP")
    field(INPD, "$(P)$(R)LowVal NPP")
    
    # 로직:
    # 현재 카운트(A)가 폭(B)보다 작으면 High(C), 아니면 Low(D)
    field(CALC, "A < B ? C : D")
}
