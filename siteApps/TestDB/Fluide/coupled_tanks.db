# ============================================================
# Coupled Tanks Simulator (Base Records Only)
# Physics: Series Tanks (Valve -> T1 -> T2 -> Drain)
# Controller: Manual PID implementation using CALC records
# ============================================================
# Macro: P = SIM:

# ------------------------------------------------------------
# 1. PID Parameters & Setpoint (Inputs)
# ------------------------------------------------------------
record(ao, "$(P)SetPoint") {
    field(DESC, "Target Level")
    field(DRVL, "0")  field(DRVH, "100")
    field(VAL,  "40")
    field(OUT,  "$(P)PID:Error.PROC PP") # 값 변경 시 PID 계산 트리거
}

record(ao, "$(P)Kp") { field(VAL, "5.0")  field(PREC, "2") }
record(ao, "$(P)Ki") { field(VAL, "2.0")  field(PREC, "2") }
record(ao, "$(P)Kd") { field(VAL, "15.0") field(PREC, "2") }

# ------------------------------------------------------------
# 2. Manual PID Controller Logic (The Base Implementation)
# Chain: Error -> Integ -> Deriv -> Output -> StorePrev
# ------------------------------------------------------------

# [Step 1] Error Calculation (e = SP - PV)
record(calc, "$(P)PID:Error") {
    field(INPA, "$(P)SetPoint NPP")
    field(INPB, "$(P)T2:Level NPP") # Feedback from Tank 2
    field(CALC, "A - B")
    field(FLNK, "$(P)PID:Integ")
}

# [Step 2] Integral Term (Accumulator with Anti-Windup)
# I_new = I_old + (Error * dt)
# Limit I_term to Avoid Windup (-50 to 50 arbitrary limits for I-term contribution)
record(calc, "$(P)PID:Integ") {
    field(INPA, "$(P)PID:Integ.VAL NPP") # Self feedback
    field(INPB, "$(P)PID:Error NPP")     # Current Error
    field(INPC, "0.1")                   # dt (Scan Rate)
    # 적분항이 너무 커지지 않도록 Clamp (-100 ~ 100)
    field(CALC, "MAX(-100, MIN(100, A + (B * C)))")
    field(FLNK, "$(P)PID:Deriv")
}

# [Step 3] Derivative Term (Delta Error)
# D_term = (Error - PrevError) / dt
record(calc, "$(P)PID:Deriv") {
    field(INPA, "$(P)PID:Error NPP")     # Current Error
    field(INPB, "$(P)PID:PrevErr NPP")   # Previous Error
    field(INPC, "0.1")                   # dt
    field(CALC, "(A - B) / C")
    field(FLNK, "$(P)PID:Output")
}

# [Step 4] PID Summation & Output (calcout)
# MV = Kp*E + Ki*I + Kd*D
record(calcout, "$(P)PID:Output") {
    field(INPA, "$(P)PID:Error NPP")
    field(INPB, "$(P)PID:Integ NPP")
    field(INPC, "$(P)PID:Deriv NPP")
    
    field(INPD, "$(P)Kp NPP")
    field(INPE, "$(P)Ki NPP")
    field(INPF, "$(P)Kd NPP")
    
    # PID Equation
    field(CALC, "(D*A) + (E*B) + (F*C)")
    
    # Output Limits (Valve 0~100%)
    field(OOPT, "On Change")
    field(DOPT, "Use CALC")
    field(OCAL, "MAX(0, MIN(100, A))") # Clamp Output 0-100
    field(OUT,  "$(P)Valve PP")
    
    field(FLNK, "$(P)PID:StorePrev")
}

# [Step 5] Store Previous Error for next cycle
record(calc, "$(P)PID:StorePrev") {
    field(INPA, "$(P)PID:Error NPP")
    field(CALC, "A")
    # End of Chain
}

# ------------------------------------------------------------
# 3. Physics Simulation (Same as before)
# ------------------------------------------------------------

# Valve (Actuator)
record(ao, "$(P)Valve") {
    field(DRVL, "0") field(DRVH, "100")
}

# --- Tank 1 (Upper) ---
record(calc, "$(P)T1:CalcOut") {
    field(INPA, "$(P)T1:Level NPP")
    field(CALC, "0.5 * SQRT(MAX(A,0))")
    field(SCAN, ".1 second") # Physics Runs independently
}
record(calc, "$(P)T1:CalcLevel") {
    field(INPA, "$(P)T1:CalcLevel.VAL NPP")
    field(INPB, "$(P)Valve NPP")
    field(INPC, "$(P)T1:CalcOut PP")
    field(CALC, "MIN(100, MAX(0, A + (B*0.5 - C*5) * 0.1))")
    field(SCAN, ".1 second")
    field(FLNK, "$(P)T1:Level")
}
record(ai, "$(P)T1:Level") {
    field(INP, "$(P)T1:CalcLevel NPP")
    field(LOPR, "0") 
    field(HOPR, "100")
}

# --- Tank 2 (Lower) ---
record(calc, "$(P)T2:CalcOut") {
    field(INPA, "$(P)T2:Level NPP")
    field(CALC, "0.4 * SQRT(MAX(A,0))")
    field(SCAN, ".1 second")
}
record(calc, "$(P)T2:CalcLevel") {
    field(INPA, "$(P)T2:CalcLevel.VAL NPP")
    field(INPB, "$(P)T1:CalcOut NPP")
    field(INPC, "$(P)T2:CalcOut PP")
    field(CALC, "MIN(100, MAX(0, A + (B*5 - C*5) * 0.1))")
    field(SCAN, ".1 second")
    field(FLNK, "$(P)T2:Level")
}
record(ai, "$(P)T2:Level") {
    field(INP, "$(P)T2:CalcLevel NPP")
    field(LOPR, "0") field(HOPR, "100")
    # Physics Loop 끝나면 PID Loop 트리거 (Feedback Loop)
    field(FLNK, "$(P)PID:Error")
}
