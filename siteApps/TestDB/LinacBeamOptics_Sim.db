# ------------------------------------------------------------------
# EPICS LINAC Simulator: Timing + RF + Beam Optics
# Logic: Timing Mismatch -> No Acceleration -> Beam Loss due to Optics mismatch
# Macro: $(P) = Prefix, $(R) = Device Name
# ------------------------------------------------------------------

# ==================================================================
# 1. 타이밍 시스템 (Timing Generator)
# ==================================================================

# 1-1. 마스터 클럭 (Time Tick)
# 0 ~ 100 까지 반복하며 시간을 시뮬레이션
record(calc, "$(P)$(R)Time:Tick") {
    field(DESC, "System Clock")
    field(SCAN, ".1 second")
    field(INPA, "$(P)$(R)Time:Tick NPP")
    field(CALC, "(A+1) % 100")
}

# 1-2. RF 펄스 생성 (RF Gate)
# 시간 10~40 구간에서 RF On
record(calc, "$(P)$(R)RF:Gate") {
    field(DESC, "RF Pulse Window")
    field(INPA, "$(P)$(R)Time:Tick CP")
    # Tick이 10~40 사이면 1, 아니면 0
    field(CALC, "(A>=10 && A<=40) ? 1 : 0")
}

# 1-3. 빔 펄스 지연 설정 (Beam Delay)
# RF 펄스보다 늦게 쏘거나 빨리 쏘는 상황 연출
record(ao, "$(P)$(R)Beam:Delay") {
    field(DESC, "Beam Trigger Delay")
    field(VAL,  "15") # 초기값: RF 윈도우(10~40) 안에 들어옴 (정상)
    field(DRVL, "0")
    field(DRVH, "100")
    field(PINI, "YES")
}

# 1-4. 빔 펄스 생성 (Beam Trigger)
# Delay 시점부터 5 Tick 동안 빔 발사
record(calc, "$(P)$(R)Beam:Gate") {
    field(DESC, "Beam Pulse Window")
    field(INPA, "$(P)$(R)Time:Tick CP")
    field(INPB, "$(P)$(R)Beam:Delay NPP")
    
    # (Tick >= Delay) && (Tick <= Delay+5)
    field(CALC, "(A>=B && A<=(B+5)) ? 1 : 0")
}

# ==================================================================
# 2. RF 가속 시스템 (RF Acceleration)
# ==================================================================

# 2-1. RF 진폭 (Amplitude)
# 가속 전압 (MV)
record(ao, "$(P)$(R)RF:Amp") {
    field(DESC, "RF Voltage")
    field(EGU,  "MeV")
    field(VAL,  "50.0") # 50 MeV 가속 능력
    field(PINI, "YES")
}

# 2-2. RF 위상 (Phase)
# 최적 가속 위상인지 확인 (deg)
record(ao, "$(P)$(R)RF:Phase") {
    field(DESC, "RF Phase")
    field(EGU,  "deg")
    field(VAL,  "0.0") # Cos(0) = 1 (최대 가속)
    field(DRVL, "-180")
    field(DRVH, "180")
}

# 2-3. 최종 빔 에너지 계산 (Energy Gain)
# E_final = E_init + (RF_Amp * cos(Phase) * Timing_Match)
record(calc, "$(P)$(R)Beam:Energy") {
    field(DESC, "Final Beam Energy")
    field(SCAN, ".1 second")
    
    field(INPA, "$(P)$(R)RF:Gate NPP")   # RF 켜졌나?
    field(INPB, "$(P)$(R)Beam:Gate NPP") # 빔 쐈나?
    field(INPC, "$(P)$(R)RF:Amp NPP")    # RF 크기
    field(INPD, "$(P)$(R)RF:Phase NPP")  # RF 위상
    
    # 초기 에너지 10 MeV 가정
    # A와 B가 모두 1일 때만(AND) 가속됨.
    # D는 degree이므로 라디안 변환(D*DR2R) 후 COS 적용
    #field(CALC, "10.0 + ((A && B) ? (C * COS(D*DR2R)) : 0)")
    field(CALC, "10.0 + ((A && B) ? (C * COS(D*D2R)) : 0)")
    
    field(EGU,  "MeV")
    field(PREC, "2")
}

# ==================================================================
# 3. 빔 광학 (Energy Dependent Optics)
# ==================================================================

# 3-1. 쿼드루폴 자석 설정값 (Magnet PS Setpoint)
# 60 MeV 빔을 집속하도록 설정된 값이라고 가정
record(ao, "$(P)$(R)Quad:K_Set") {
    field(DESC, "Quad Strength Setpoint")
    field(VAL,  "2.0")
    field(PINI, "YES")
}

# 3-2. 유효 자석 세기 (Effective K) - 핵심 물리 로직
# 빔 에너지가 변하면 자석이 빔에 미치는 영향력(K_eff)이 변함
# K_eff = K_set * (E_design / E_actual)
record(calc, "$(P)$(R)Quad:K_Eff") {
    field(DESC, "Effective Focusing Strength")
    field(INPA, "$(P)$(R)Quad:K_Set NPP")    # 설정값
    field(INPB, "$(P)$(R)Beam:Energy CP")     # 현재 빔 에너지
    
    # 기준 에너지(Design Energy)를 60 MeV로 가정
    # 에너지가 낮으면(B<60) 자석이 너무 세게 작용(Over-focusing)
    # 에너지가 높으면(B>60) 자석이 약하게 작용(Under-focusing)
    field(CALC, "A * (60.0 / MAX(1.0, B))")
    
    field(PREC, "3")
}

# 3-3. 빔 전송 시뮬레이션 (Drift-Quad-Drift)
# 앞선 Transfer Matrix 예제의 간소화 버전
# 입사 조건: 중심에서 1mm 벗어난 평행광
record(calc, "$(P)$(R)Beam:Pos") {
    field(DESC, "Beam Position on Screen")
    field(SCAN, ".1 second")
    
    field(INPA, "$(P)$(R)Quad:K_Eff CP") # 에너지에 따라 변하는 K값
    
    # 물리 모델 (L1=1m, Lq=0.2m, L2=1m, x0=1mm)
    # x_final = x0 * (1 - L2 * K_eff * Lq) (근사식)
    # K_eff가 적절하면 0으로 수렴(Focus), 아니면 발산
    field(CALC, "1.0 * (1 - (1.0 * A * 0.2))")
    
    field(EGU,  "mm")
    field(PREC, "3")
}

# 3-4. 빔 상태 판정 (Beam Loss Monitor)
record(calc, "$(P)$(R)Beam:Status") {
    field(INPA, "$(P)$(R)Beam:Pos CP")
    # 위치가 ±2mm 벗어나면 Beam Loss
    field(CALC, "ABS(A) > 2.0 ? 0 : 1") 
}
