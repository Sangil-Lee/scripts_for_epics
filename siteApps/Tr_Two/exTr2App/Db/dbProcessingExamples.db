#======================================================================
#  EPICS DB Processing 초급자 교육 예제
#======================================================================
#
#  이 파일은 EPICS 레코드 간 데이터 흐름과 처리(Processing) 개념을
#  학습하기 위한 3가지 독립 예제를 담고 있습니다.
#
#  로드: dbLoadRecords("db/dbProcessingExamples.db", "P=TEST")
#
#  ====================================================================
#  핵심 개념 요약
#  ====================================================================
#
#  [PP / NPP  — 출력 링크의 처리 전파]
#    PP  (Process Passive) : 링크 대상 레코드가 Passive이면 처리를 유발
#    NPP (No Process)      : 값만 전달하고 처리를 유발하지 않음
#
#  [CP / CPP  — 입력 링크의 모니터]
#    CP  (Channel Process)         : 소스가 변경되면 이 레코드를 처리
#    CPP (Channel Process Passive) : 위와 같지만 이 레코드가 Passive일 때만
#
#  [FLNK — Forward Link]
#    현재 레코드 처리가 끝난 뒤 다음 레코드의 처리를 촉발하는 체인
#
#  [SCAN — 주기적 처리]
#    "Passive"  : 외부 요청(caput, 링크)이 있어야 처리
#    "1 second" : 1초마다 자동 처리
#    "I/O Intr" : 하드웨어/드라이버 인터럽트 시 처리
#
#  ====================================================================
#
#
#######################################################################
#  예제 1.  Forward Link Chain (FLNK) — 순차 처리 체인
#######################################################################
#
#  개요:
#    온도 센서 값을 읽어 → 섭씨→화씨 변환 → 상태 판정까지
#    3개 레코드가 FLNK로 자동 연쇄 처리되는 파이프라인.
#
#  데이터 흐름:
#    TempRaw(ai) --FLNK--> TempFahrenheit(calc) --FLNK--> TempStatus(calc)
#
#  시험 방법:
#    # 1) 섭씨 온도 입력 (FLNK 체인이 자동으로 나머지를 처리)
#    caput TEST:TempRaw 25.0
#
#    # 2) 결과 확인
#    caget TEST:TempRaw              # 25.0
#    caget TEST:TempFahrenheit       # 77.0  (= 25 * 9/5 + 32)
#    caget TEST:TempStatus           # 1     (정상 범위)
#
#    # 3) 고온 시험
#    caput TEST:TempRaw 85.0
#    caget TEST:TempFahrenheit       # 185.0
#    caget TEST:TempStatus           # 2     (고온 경보)
#    caget TEST:TempStatus.SEVR      # MAJOR (알람 확인)
#
#    # 4) 저온 시험
#    caput TEST:TempRaw -15.0
#    caget TEST:TempFahrenheit       # 5.0
#    caget TEST:TempStatus           # 0     (저온 경보)
#
#    # 5) 학습 포인트
#    #    - TempRaw 하나만 caput 했는데 3개 레코드 모두 갱신됨
#    #    - 이것이 FLNK 체인의 핵심: "하나를 처리하면 줄줄이 처리"
#----------------------------------------------------------------------

# [1-1] 온도 입력 (섭씨)
#   - 운전자가 caput 으로 값을 넣으면 처리 시작
#   - 처리가 끝나면 FLNK → TempFahrenheit 로 이동
record(ai, "$(P):TempRaw") {
    field(DESC, "Temperature input (Celsius)")
    field(EGU,  "degC")
    field(PREC, "1")
    field(HOPR, "150")
    field(LOPR, "-50")
    field(FLNK, "$(P):TempFahrenheit")
}

# [1-2] 섭씨 → 화씨 변환 (calc 레코드)
#   - INPA 로 TempRaw 값을 읽어옴 (NPP: 값만 읽고 재처리 안 함)
#   - CALC 수식: F = C * 9/5 + 32
#   - 처리가 끝나면 FLNK → TempStatus 로 이동
record(calc, "$(P):TempFahrenheit") {
    field(DESC, "Celsius to Fahrenheit")
    field(INPA, "$(P):TempRaw NPP")
    field(CALC, "A*9/5+32")
    field(EGU,  "degF")
    field(PREC, "1")
    field(FLNK, "$(P):TempStatus")
}

# [1-3] 온도 상태 판정 (calc 레코드)
#   - A = 섭씨 원본값
#   - 결과: 0=저온(<0), 1=정상(0~80), 2=고온(>80)
#   - HIGH/HSV: 값이 2 이상이면 MAJOR 알람 발생
record(calc, "$(P):TempStatus") {
    field(DESC, "Temp status: 0=Low 1=OK 2=High")
    field(INPA, "$(P):TempRaw NPP")
    field(CALC, "A<0?0:(A>80?2:1)")
    field(HIGH, "2")
    field(HSV,  "MAJOR")
}


#######################################################################
#  예제 2.  CP Link — 입력 변경 시 자동 처리 (이벤트 구동)
#######################################################################
#
#  개요:
#    전압(V)과 전류(I)를 각각 독립적으로 입력하면,
#    어느 쪽이 바뀌든 전력(P=V*I) 레코드가 자동 재계산된다.
#    FLNK 없이 CP 링크만으로 처리가 유발되는 패턴.
#
#  데이터 흐름:
#    Voltage(ao) --CP--> Power(calc)
#    Current(ao) --CP-┘
#                         |
#                        FLNK
#                         v
#                     Resistance(calc)
#
#  시험 방법:
#    # 1) 전압 설정
#    caput TEST:Voltage 12.0
#    caget TEST:Power                # 0.0 (전류가 아직 0)
#
#    # 2) 전류 설정 → Power 자동 계산
#    caput TEST:Current 2.5
#    caget TEST:Power                # 30.0 (= 12.0 * 2.5)
#    caget TEST:Resistance           # 4.8  (= 12.0 / 2.5)
#
#    # 3) 전압만 변경 → Power 자동 재계산
#    caput TEST:Voltage 24.0
#    caget TEST:Power                # 60.0 (= 24.0 * 2.5)
#    caget TEST:Resistance           # 9.6  (= 24.0 / 2.5)
#
#    # 4) 전류 0 → 저항 보호 확인
#    caput TEST:Current 0
#    caget TEST:Power                # 0.0
#    caget TEST:Resistance           # 0.0  (0 나누기 보호 → 0 출력)
#
#    # 5) 학습 포인트
#    #    - caput 은 Voltage 또는 Current 에만 했는데 Power 가 자동 갱신
#    #    - CP 링크: "소스가 바뀌면 나를 처리해줘"
#    #    - FLNK 과 달리, 여러 소스 중 아무거나 바뀌어도 반응
#----------------------------------------------------------------------

# [2-1] 전압 입력
record(ao, "$(P):Voltage") {
    field(DESC, "Voltage input")
    field(EGU,  "V")
    field(PREC, "2")
    field(DRVH, "500")
    field(DRVL, "0")
    field(VAL,  "0")
}

# [2-2] 전류 입력
record(ao, "$(P):Current") {
    field(DESC, "Current input")
    field(EGU,  "A")
    field(PREC, "3")
    field(DRVH, "100")
    field(DRVL, "0")
    field(VAL,  "0")
}

# [2-3] 전력 계산 (P = V * I)
#   - INPA, INPB 에 "CP" 를 사용
#   - Voltage 또는 Current 가 변경되면 이 레코드가 자동 처리됨
record(calc, "$(P):Power") {
    field(DESC, "Power = V * I")
    field(INPA, "$(P):Voltage CP")
    field(INPB, "$(P):Current CP")
    field(CALC, "A*B")
    field(EGU,  "W")
    field(PREC, "2")
    field(FLNK, "$(P):Resistance")
}

# [2-4] 저항 계산 (R = V / I, 0 나누기 보호)
#   - Power 의 FLNK 에 의해 연쇄 처리
#   - CALC 에서 B=0 일 때 0 을 반환하여 0 나누기 방지
record(calc, "$(P):Resistance") {
    field(DESC, "Resistance = V / I")
    field(INPA, "$(P):Voltage NPP")
    field(INPB, "$(P):Current NPP")
    field(CALC, "B=0?0:A/B")
    field(EGU,  "Ohm")
    field(PREC, "2")
}


#######################################################################
#  예제 3.  Periodic SCAN + fanout — 주기 처리와 다중 분기
#######################################################################
#
#  개요:
#    1초 주기로 카운터가 증가하면서, fanout 레코드를 통해
#    여러 후속 레코드(짝수/홀수 판정, 10진 카운터 리셋)를
#    동시에 처리하는 패턴.
#
#  데이터 흐름:
#    Counter(calc, SCAN=1sec) --FLNK--> CounterFan(fanout)
#                                           |
#                              +------------+------------+
#                              v            v            v
#                        IsEven(calc)  Mod10(calc)  TickMsg(scalcout)
#
#  시험 방법:
#    # 1) IOC 기동 후 자동으로 1초마다 카운터 증가 확인
#    camonitor TEST:Counter
#    #   TEST:Counter  2026-03-31 10:00:01  1
#    #   TEST:Counter  2026-03-31 10:00:02  2
#    #   TEST:Counter  2026-03-31 10:00:03  3  ...
#
#    # 2) 짝수/홀수 판정 확인
#    camonitor TEST:IsEven
#    #   카운터 1 → 0 (홀수)
#    #   카운터 2 → 1 (짝수)
#    #   카운터 3 → 0 (홀수) ...
#
#    # 3) 10진 카운터 (0~9 순환) 확인
#    camonitor TEST:Mod10
#    #   0, 1, 2, ... 9, 0, 1, 2, ...
#
#    # 4) 메시지 레코드 확인
#    camonitor TEST:TickMsg
#    #   "Even" 또는 "Odd" 가 번갈아 표시
#
#    # 5) 카운터 수동 리셋
#    caput TEST:Counter 0
#    caget TEST:Counter               # 다음 1초 뒤 1 부터 재시작
#
#    # 6) 학습 포인트
#    #    - SCAN="1 second": 외부 요청 없이 자동으로 주기 처리
#    #    - fanout: 하나의 FLNK로 여러 레코드를 동시 분기 처리
#    #    - 카운터 + fanout 조합은 주기적 모니터링 패턴의 기본형
#----------------------------------------------------------------------

# [3-1] 1초 주기 카운터
#   - SCAN="1 second" 로 매 1초마다 자동 처리
#   - CALC="VAL+1" : 자기 자신의 이전 값에 1을 더함
#   - 처리 완료 후 FLNK → CounterFan (fanout) 으로 분기
record(calc, "$(P):Counter") {
    field(DESC, "1-sec auto counter")
    field(SCAN, "1 second")
    field(CALC, "VAL+1")
    field(FLNK, "$(P):CounterFan")
}

# [3-2] fanout — 여러 레코드를 동시에 처리 유발
#   - LNK1~LNK3 에 연결된 레코드들이 모두 처리됨
#   - 하나의 FLNK만으로 다중 분기가 가능한 핵심 레코드
record(fanout, "$(P):CounterFan") {
    field(DESC, "Fan out to multiple records")
    field(LNK1, "$(P):IsEven")
    field(LNK2, "$(P):Mod10")
    field(LNK3, "$(P):TickMsg")
}

# [3-3] 짝수/홀수 판정
#   - Counter 값을 2로 나눈 나머지가 0 이면 1(짝수), 아니면 0(홀수)
record(calc, "$(P):IsEven") {
    field(DESC, "1=Even, 0=Odd")
    field(INPA, "$(P):Counter NPP")
    field(CALC, "A%2=0?1:0")
}

# [3-4] 10진 순환 카운터 (0~9)
#   - Counter 값을 10으로 나눈 나머지
record(calc, "$(P):Mod10") {
    field(DESC, "Counter mod 10 (0-9)")
    field(INPA, "$(P):Counter NPP")
    field(CALC, "A%10")
}

# [3-5] 짝수/홀수 문자열 메시지 (scalcout 레코드)
#   - A 에 IsEven 결과(0 또는 1)를 읽어서
#   - A=1 이면 "Even", A=0 이면 "Odd" 를 OSV(출력 문자열)에 생성
record(scalcout, "$(P):TickMsg") {
    field(DESC, "Even/Odd message")
    field(INPA, "$(P):IsEven NPP")
    field(AA,   "Even")
    field(BB,   "Odd")
    field(CALC, "A")
    field(OCAL, "A?AA:BB")
    field(OOPT, "Every Time")
    field(DOPT, "Use OCAL")
}
